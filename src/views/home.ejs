<div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-6">
  <div class="bg-white p-6 rounded-2xl shadow">
    <h2 class="text-gray-500">Total Mahasiswa</h2>
    <p class="text-3xl font-bold text-blue-600">120</p>
  </div>
  <div class="bg-white p-6 rounded-2xl shadow">
    <h2 class="text-gray-500">Total Dosen</h2>
    <p class="text-3xl font-bold text-green-600">35</p>
  </div>
  <div class="bg-white p-6 rounded-2xl shadow">
    <h2 class="text-gray-500">Total Matkul</h2>
    <p class="text-3xl font-bold text-purple-600">50</p>
  </div>
</div>

<div class="bg-white p-6 rounded-2xl shadow">
  <h2 class="text-xl font-bold mb-4">Data Mahasiswa</h2>
  <table class="w-full border-collapse border border-gray-200">
    <thead>
      <tr class="bg-gray-100">
        <th class="border p-2">No</th>
        <th class="border p-2">Nama</th>
        <th class="border p-2">NIM</th>
      </tr>
    </thead>
    <tbody>
      <% if (mahasiswa && mahasiswa.length> 0) { %>
        <% mahasiswa.forEach((m, index)=> { %>
          <tr>
            <td class="border p-2">
              <%= index + 1 %>
            </td>
            <td class="border p-2">
              <%= m.nama %>
            </td>
            <td class="border p-2">
              <%= m.nim %>
            </td>
          </tr>
          <% }) %>
            <% } else { %>
              <tr>
                <td colspan="3" class="border p-2 text-center">Belum ada data</td>
              </tr>
              <% } %>
    </tbody>
  </table>
</div>